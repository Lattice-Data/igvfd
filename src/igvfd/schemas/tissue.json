{
    "title": "Tissue",
    "$id": "/profiles/tissue.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A concrete tissue sample schema inheriting from abstract Biosample class.",
    "type": "object",
    "required": [
        "lab",
        "donors",
        "sample_terms"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/author_metadata"
        },
        {
            "$ref": "biosample.json#/properties"
        },
        {
            "$ref": "mixins.json#/biosample_age_range"
        }
    ],
    "dependentSchemas": {
        "$merge": [
            "biosample.json#/dependentSchemas",
            "mixins.json#/tissue_thickness_dependent_schemas"
        ]
    },
    "properties": {
        "schema_version": {
            "default": "1"
        },
        "spatial_information": {
            "title": "Spatial Information",
            "description": "Text about spatial information of the tissue.",
            "type": "string"
        },
        "preservation_method": {
            "title": "Preservation Method",
            "description": "The method used to preserve the tissue sample.",
            "type": "string",
            "enum": [
                "fresh",
                "frozen",
                "flash-frozen",
                "fixed",
                "fixed-frozen",
                "cryopreserved",
                "paraffin embedded",
                "OCT embedded"
            ]
        },
        "thickness": {
            "title": "Thickness",
            "description": "The thickness of the tissue sample.",
            "type": "number",
            "minimum": 0
        },
        "thickness_units": {
            "title": "Thickness Units",
            "description": "The unit of thickness measurement.",
            "type": "string",
            "enum": [
                "μm",
                "mm",
                "cm"
            ]
        },
        "date_obtained": {
            "title": "Date Obtained",
            "description": "The date the tissue sample was collected.",
            "type": "string",
            "format": "date"
        },
        "orientation": {
            "title": "Orientation",
            "description": "The orientation of the tissue sample.",
            "type": "string",
            "enum": [
                "coronal",
                "lateral",
                "longitudinal",
                "sagittal",
                "transverse"
            ]
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description",
        "sample_terms.term_name",
        "spatial_information"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/tissue.md"
}
