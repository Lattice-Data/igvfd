{
    "title": "Matrix File Set",
    "$id": "/profiles/matrix_file_set.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A set of matrix files produced from processing sequence data.",
    "type": "object",
    "required": [
        "lab"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "file_set.json#/properties"
        }
    ],
    "properties": {
        "schema_version": {
            "default": "2"
        },
        "raw_matrix_files": {
            "title": "Raw Matrix Files",
            "description": "Raw matrix files in this set.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Raw Matrix File",
                "description": "A raw matrix file.",
                "comment": "See raw_matrix_file.json for available identifiers.",
                "type": "string",
                "linkTo": "RawMatrixFile"
            },
            "submissionExample": {
                "appscript": "[\"john-doe:raw-matrix-001\"]"
            }
        },
        "processed_matrix_files": {
            "title": "Processed Matrix Files",
            "description": "Processed matrix files in this set.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Processed Matrix File",
                "description": "A processed matrix file.",
                "comment": "See processed_matrix_file.json for available identifiers.",
                "type": "string",
                "linkTo": "ProcessedMatrixFile"
            },
            "submissionExample": {
                "appscript": "[\"john-doe:processed-matrix-001\"]"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/matrix_file_set.md"
}
