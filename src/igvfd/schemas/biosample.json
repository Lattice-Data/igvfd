        "suspension_type": {
            "title": "Suspension Type",
            "description": "Type of suspension - single cells or single nuclei.",
            "type": "string",
            "enum": [
                "cell",
                "nucleus"
            ]
        },
        "genetic_modification": {
            "title": "Genetic Modification",
            "description": "Genetic modification applied to this biosample.",
            "comment": "See genetic_modification.json for available identifiers.",
            "type": "string",
            "linkTo": "GeneticModification"
        },
        "enrichment_method": {
            "title": "Enrichment Method",
            "description": "Method used for cell enrichment or sorting.",
            "type": "string",
            "enum": [
                "FACS",
                "MACS",
                "size exclusion",
                "density gradient",
                "manual picking",
                "microfluidics"
            ]
        },
        "enriched_cell_types": {
            "title": "Enriched Cell Types",
            "description": "Cell types that were enriched in this sample. Must reference ControlledTerm objects with Cell Ontology (CL) terms.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Enriched Cell Type",
                "description": "Reference to ControlledTerm with Cell Ontology (CL) term for enriched cell type.",
                "comment": "Must link to ControlledTerm with ontology_source='CL'. See controlled_term.json for available identifiers.",
                "type": "string",
                "linkTo": "ControlledTerm"
            }
        },
        "depleted_cell_types": {
            "title": "Depleted Cell Types",
            "description": "Cell types that were depleted from this sample. Must reference ControlledTerm objects with Cell Ontology (CL) terms.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Depleted Cell Type",
                "description": "Reference to ControlledTerm with Cell Ontology (CL) term for depleted cell type.",
                "comment": "Must link to ControlledTerm with ontology_source='CL'. See controlled_term.json for available identifiers.",
                "type": "string",
                "linkTo": "ControlledTerm"
            }
        },
        "enrichment_markers": {
            "title": "Enrichment Markers",
            "description": "Markers used for cell enrichment or depletion.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "marker",
                    "expression_level"
                ],
                "properties": {
                    "marker": {
                        "title": "Marker",
                        "description": "Cell surface marker or protein used for enrichment.",
                        "type": "string",
                        "enum": [
                            "CD3",
                            "CD4",
                            "CD8",
                            "CD14",
                            "CD16",
                            "CD19",
                            "CD20",
                            "CD31",
                            "CD34",
                            "CD45",
                            "CD56",
                            "CD90",
                            "CD123",
                            "CD141",
                            "CD144",
                            "CD205"
                        ]
                    },
                    "expression_level": {
                        "title": "Expression Level",
                        "description": "Level of marker expression used for selection.",
                        "type": "string",
                        "enum": [
                            "positive",
                            "negative",
                            "low",
                            "high",
                            "intermediate"
                        ]
                    }
                }
            }
        },
        "experimental_conditions": {
            "title": "Experimental Conditions",
            "description": "Environmental and experimental parameters affecting the sample.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Experimental Condition",
                "description": "Reference to experimental condition applied to this sample.",
                "comment": "See experimental_condition.json for available identifiers.",
                "type": "string",
                "linkTo": "ExperimentalCondition"
            }
        },
        "treatments": {
            "title": "Treatments",
            "description": "Treatments applied to this biosample (ChEBI/UniProt agents).",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Treatment",
                "description": "Reference to treatment applied to this sample.",
                "comment": "See treatment.json for available identifiers.",
                "type": "string",
                "linkTo": "Treatment"
            }
        },
        "sources": {
            "title": "Sources",
            "description": "The originating lab(s) or vendor(s) that provided the biological material.",
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Source",
                "description": "The originating lab or vendor.",
                "type": "string",
                "comment": "See source.json or lab.json for available identifiers.",
                "linkTo": [
                    "Source",
                    "Lab"
                ]
            },
            "submissionExample": {
                "appscript": "[\"/labs/john-doe/\", \"/sources/abcam/\"]",
                "igvf_utils": "/labs/john-doe/, /sources/abcam/"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description",
        "sample_terms.term_name",
        "sources.title"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/biosample.md"
}
