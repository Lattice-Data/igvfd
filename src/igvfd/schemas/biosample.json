{
    "title": "Biosample",
    "description": "Abstract schema for biological samples.",
    "$id": "/profiles/biosample.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
        "lab",
        "donors",
        "sample_terms"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/dbxrefs"
        }
    ],
    "dependentSchemas": {
        "sample_procurement_interval": {
            "required": [
                "sample_procurement_interval_units"
            ]
        },
        "sample_procurement_interval_units": {
            "required": [
                "sample_procurement_interval"
            ]
        },
        "lower_bound_age": {
            "required": [
                "upper_bound_age",
                "age_units"
            ]
        },
        "upper_bound_age": {
            "required": [
                "lower_bound_age",
                "age_units"
            ]
        },
        "age_units": {
            "required": [
                "lower_bound_age",
                "upper_bound_age"
            ]
        }
    },
    "properties": {
        "schema_version": {
            "default": "2"
        },
        "dbxrefs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "External identifier",
                "description": "An identifier from external resource.",
                "type": "string",
                "pattern": "^((EGA:EGAN\\d+)|(BioSample:SAM(E|N|D)(A|G)?\\d+)|(SRA:SRS\\d+)|(ENA:ERS\\d+))$"
            }
        },
        "donors": {
            "title": "Donors",
            "description": "Donor(s) the sample was derived from.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Donor",
                "description": "Donor.",
                "comment": "See donor.json for available identifiers.",
                "type": "string",
                "linkTo": "Donor"
            }
        },
        "sample_terms": {
            "title": "Sample Terms",
            "description": "Ontology terms identifying a biosample.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Sample Term",
                "description": "Ontology term identifying a biosample.",
                "comment": "See controlled_term.json for available identifiers.",
                "type": "string",
                "linkTo": "ControlledTerm"
            }
        },
        "diseases": {
            "title": "Diseases",
            "description": "Known diseases thought to, or being tested to, impact the measurement being taken, and not necessarily diseases of the donor from which the sample was obtained.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Disease",
                "description": "Reference to a disease ontology term.",
                "comment": "See controlled_term.json for available identifiers.",
                "type": "string",
                "linkTo": "ControlledTerm"
            }
        },
        "developmental_stages": {
            "title": "Developmental Stages",
            "description": "The developmental stage(s) of the donor at the time the biosample was obtained.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Developmental Stage",
                "description": "Reference to a developmental-stage ontology term.",
                "comment": "Link to a ControlledTerm with a developmental-stage ontology (e.g. HsapDv, MmusDv). See controlled_term.json for available identifiers.",
                "type": "string",
                "linkTo": "ControlledTerm",
                "submissionExample": {
                    "appscript": "lattice:term-dev-stage-human-embryonic"
                }
            }
        },
        "sample_procurement_interval": {
            "title": "Sample Procurement Interval",
            "description": "Time passing from the moment of sample collection till the freezing or initiation of the experiment with the sample.",
            "type": "integer",
            "minimum": 0
        },
        "sample_procurement_interval_units": {
            "title": "Sample Procurement Interval Units",
            "description": "The unit in which the sample procurement interval was reported.",
            "type": "string",
            "enum": [
                "second",
                "minute",
                "hour",
                "day",
                "week"
            ]
        },
        "date_obtained": {
            "title": "Date Obtained",
            "description": "The date the sample was collected.",
            "type": "string",
            "format": "date"
        },
        "collection_geographical_location": {
            "title": "Collection Geographical Location",
            "description": "The geographic location where the sample was collected. Enum values follow INSDC /geo_loc_name qualifier vocabulary: https://www.insdc.org/submitting-standards/geo_loc_name-qualifier-vocabulary/",
