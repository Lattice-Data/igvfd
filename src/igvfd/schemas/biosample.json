        "suspension_type": {
            "title": "Suspension Type",
            "description": "Type of suspension - single cells or single nuclei.",
            "type": "string",
            "enum": [
                "cell",
                "nucleus"
            ]
        },
        "genetic_modification": {
            "title": "Genetic Modification",
            "description": "Genetic modification applied to this biosample.",
            "comment": "See genetic_modification.json for available identifiers.",
            "type": "string",
            "linkTo": "GeneticModification"
        },
        "selection_kits": {
            "title": "Selection Kits",
            "description": "Commercial kit(s) used for isolation or sorting when that workflow applies.",
            "comment": "Optional. Omit unless selection was driven by a defined catalog kit. Enum values use plain ASCII (no trademark symbol; Naive without diacritic) for easier submission; they correspond to the EasySep product names.",
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Selection Kit",
                "description": "Commercial kit used for isolation or sorting.",
                "type": "string",
                "enum": [
                    "EasySep Human Naive CD4+ T Cell Isolation Kit II",
                    "EasySep Human CD4+CD127lowCD25+ Regulatory T Cell Isolation Kit",
                    "EasySep Human Monocyte Enrichment Kit without CD16 Depletion"
                ]
            },
            "submissionExample": {
                "appscript": "[\"EasySep Human Naive CD4+ T Cell Isolation Kit II\"]"
            }
        },
        "selection_methods": {
            "title": "Selection Methods",
            "description": "Approach used to isolate or enrich fractions of interest (for example immunophenotype-based sorting, size selection, gradient separation, manual handling, microfluidics, or use of a commercial kit).",
            "comment": "When submitted, exactly one method applies.",
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Selection Method",
                "description": "Selection or sorting approach.",
                "type": "string",
                "enum": [
                    "MACS",
                    "FACS",
                    "size selection",
                    "density gradient",
                    "manual selection",
                    "microfluidics",
                    "selection kit"
                ]
            },
            "submissionExample": {
                "appscript": "[\"FACS\"]"
            }
        },
        "selection_markers": {
            "title": "Selection Markers",
            "description": "Descriptors of how fractions were defined or gated for selection (for example surface markers, physical size classes, or lipid dye gates).",
            "comment": "When submitted, include every distinct gate or marker class used; omit if selection was not characterized this way.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Selection Marker",
                "description": "A defined marker, gate, or fraction label used during selection.",
                "type": "string",
                "enum": [
                    "CD123+",
                    "CD123-",
                    "CD14+",
                    "CD14-",
                    "CD141+",
                    "CD141-",
                    "CD144+",
                    "CD144-",
                    "CD16+",
                    "CD16-",
                    "CD19+",
                    "CD19-",
                    "CD20+",
                    "CD20-",
                    "CD205+",
                    "CD205-",
                    "CD3+",
                    "CD3-",
                    "CD31+",
                    "CD31-",
                    "CD34+",
                    "CD34-",
                    "CD4+",
                    "CD4-",
                    "CD45+",
                    "CD45-",
                    "CD56+",
                    "CD56-",
                    "CD8+",
                    "CD8-",
                    "CD90+",
                    "CD90-",
                    "large size",
                    "lipid stain (bottom 30%)",
                    "lipid stain (top 30%)",
                    "small size"
                ]
            },
            "submissionExample": {
                "appscript": "[\"CD4+\", \"CD8-\"]"
            }
        },
        "enriched_cell_types": {
            "title": "Enriched Cell Types",
            "description": "Cell types enriched in this sample. Must reference ControlledTerm objects with Cell Ontology (CL) terms. A full listing of every enriched population is not required unless that level of detail reflects the experimental intent.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Enriched Cell Type",
                "description": "Reference to ControlledTerm with Cell Ontology (CL) term for enriched cell type.",
                "comment": "Must link to ControlledTerm with ontology_source='CL'. See controlled_term.json for available identifiers.",
                "type": "string",
                "linkTo": "ControlledTerm"
            }
        },
        "depleted_cell_types": {
            "title": "Depleted Cell Types",
            "description": "Cell types depleted from this sample. Must reference ControlledTerm objects with Cell Ontology (CL) terms. A full listing of every depleted population is not required unless that level of detail reflects the experimental intent.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Depleted Cell Type",
                "description": "Reference to ControlledTerm with Cell Ontology (CL) term for depleted cell type.",
                "comment": "Must link to ControlledTerm with ontology_source='CL'. See controlled_term.json for available identifiers.",
                "type": "string",
                "linkTo": "ControlledTerm"
            }
        },
        "experimental_conditions": {
            "title": "Experimental Conditions",
            "description": "Environmental and experimental parameters affecting the sample.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Experimental Condition",
                "description": "Reference to experimental condition applied to this sample.",
                "comment": "See experimental_condition.json for available identifiers.",
                "type": "string",
                "linkTo": "ExperimentalCondition"
            }
        },
        "treatments": {
            "title": "Treatments",
            "description": "Treatments applied to this biosample (ChEBI/UniProt agents).",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Treatment",
                "description": "Reference to treatment applied to this sample.",
                "comment": "See treatment.json for available identifiers.",
                "type": "string",
                "linkTo": "Treatment"
            }
        },
        "sources": {
            "title": "Sources",
            "description": "The originating lab(s) or vendor(s) that provided the biological material.",
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Source",
                "description": "The originating lab or vendor.",
                "type": "string",
                "comment": "See source.json or lab.json for available identifiers.",
                "linkTo": [
                    "Source",
                    "Lab"
                ]
            },
            "submissionExample": {
                "appscript": "[\"/labs/john-doe/\", \"/sources/abcam/\"]"
            }
        },
        "hash_index": {
            "title": "Hash Index",
            "description": "Identifier for oligo-based sample hashing (hashtag demultiplexing), tagging this biosample with the hashtag oligo used during multiplexed library preparation.",
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$",
            "submissionExample": {
                "appscript": "P01-A1"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description",
        "hash_index",
        "sample_terms.term_name",
        "developmental_stages.term_name",
        "sources.title"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/biosample.md"
}
