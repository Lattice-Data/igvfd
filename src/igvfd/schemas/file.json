{
    "title": "File",
    "$id": "/profiles/file.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Abstract schema for submission of a file.",
    "type": "object",
    "required": [
        "lab",
        "file_format"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        }
    ],
    "allOf": [
        {
            "if": {
                "required": [
                    "no_file_available"
                ],
                "properties": {
                    "no_file_available": {
                        "const": true
                    }
                }
            },
            "then": {
                "not": {
                    "anyOf": [
                        {
                            "required": [
                                "s3_uri"
                            ]
                        },
                        {
                            "required": [
                                "crc64nvme_base64"
                            ]
                        }
                    ]
                }
            },
            "else": {
                "required": [
                    "s3_uri",
                    "crc64nvme_base64"
                ]
            }
        }
    ],
    "properties": {
        "schema_version": {
            "default": "2"
        },
        "file_format": {
            "title": "File Format",
            "description": "The file format or extension of the file.",
            "comment": "This property is overwritten by the subclasses to define specific enum values.",
            "type": "string",
            "submissionExample": {
                "appscript": "bam"
            }
        },
        "file_size": {
            "title": "File Size",
            "description": "File size specified in bytes.",
            "type": "integer",
            "minimum": 0
        },
        "s3_uri": {
            "title": "S3 URI",
            "description": "The S3 URI where the file is stored.",
            "type": "string",
            "pattern": "^s3://.+",
            "submissionExample": {
                "appscript": "s3://igvfd-bucket/path/to/file.fastq.gz"
            }
        },
        "crc64nvme_base64": {
            "title": "CRC64NVME checksum (Base64)",
            "description": "Base64-encoded CRC64NVME checksum as reported by AWS S3.",
            "comment": "Submit the Base64-encoded CRC64NVME checksum from S3 when the file is available (no_file_available is false). When no_file_available is true, omit both s3_uri and crc64nvme_base64.",
            "type": "string",
            "pattern": "^[A-Za-z0-9+/]{11}={0,2}$",
            "submissionExample": {
                "appscript": "AAAAAAAAAAA"
            }
        },
        "no_file_available": {
            "title": "No File Available",
            "description": "Set to true when no file is available for this record.",
            "type": "boolean",
            "default": false
        },
        "derived_from": {
            "title": "Derived From",
            "description": "The files participating as inputs into software to produce this output file.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "File Derived From",
                "comment": "See file.json for a list of available identifiers.",
                "type": "string",
                "linkTo": "File"
            },
            "submissionExample": {
                "appscript": "[\"IGVFFI1234ABCD\", \"john-doe:file01\"]"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/file.md"
}
