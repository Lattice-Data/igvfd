{
    "title": "Plate Based Library",
    "$id": "/profiles/plate_based_library.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Plate-based single cell library using 96/384-well workflow.",
    "type": "object",
    "required": [
        "lab",
        "samples",
        "library_cardinality"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/author_metadata"
        },
        {
            "$ref": "library.json#/properties"
        }
    ],
    "dependentSchemas": {
        "$merge": [
            "library.json#/dependentSchemas"
        ]
    },
    "properties": {
        "schema_version": {
            "default": "3"
        },
        "linked_libraries": {
            "title": "Linked Libraries",
            "description": "Plate-based libraries that are grouped with this library.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Linked Library",
                "description": "A plate-based library grouped with this library.",
                "comment": "See plate_based_library.json for available identifiers. This property is affected by dependencies. Requires library_cardinality to be 'dual'.",
                "type": "string",
                "linkTo": "PlateBasedLibrary"
            },
            "submissionExample": {
                "appscript": "[\"lattice:plate-library-partner-a\"]"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/plate_based_library.md"
}
