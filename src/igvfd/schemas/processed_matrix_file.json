{
    "title": "Processed Matrix File",
    "$id": "/profiles/processed_matrix_file.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A file containing a processed matrix in H5AD format.",
    "type": "object",
    "required": [
        "lab",
        "md5sum",
        "file_format"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/matrix_shared"
        },
        {
            "$ref": "file.json#/properties"
        }
    ],
    "dependentSchemas": {
        "$merge": [
            "file.json#/dependentSchemas"
        ]
    },
    "properties": {
        "schema_version": {
            "default": "1"
        },
        "file_format": {
            "title": "File Format",
            "description": "The file format or extension of the file.",
            "type": "string",
            "enum": [
                "h5ad"
            ],
            "submissionExample": {
                "appscript": "h5ad"
            }
        },
        "matrix_file_sets": {
            "title": "Matrix File Sets",
            "description": "Matrix file sets that include this processed matrix file.",
            "type": "array",
            "items": {
                "title": "Matrix File Set",
                "type": "string",
                "linkFrom": "MatrixFileSet.processed_matrix_files"
            },
            "notSubmittable": true
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/processed_matrix_file.md"
}
