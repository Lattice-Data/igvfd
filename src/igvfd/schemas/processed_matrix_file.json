{
    "title": "Processed Matrix File",
    "$id": "/profiles/processed_matrix_file.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A file containing a processed matrix in H5AD format.",
    "type": "object",
    "required": [
        "lab",
        "file_format",
        "is_multiplexed"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/matrix_shared"
        },
        {
            "$ref": "file.json#/properties"
        }
    ],
    "allOf": [
        {
            "$merge": [
                "file.json#/allOf/0"
            ]
        }
    ],
    "properties": {
        "schema_version": {
            "default": "4"
        },
        "file_format": {
            "title": "File Format",
            "description": "The file format or extension of the file.",
            "type": "string",
            "enum": [
                "h5ad"
            ],
            "submissionExample": {
                "appscript": "h5ad"
            }
        },
        "is_multiplexed": {
            "title": "Is Multiplexed",
            "description": "Whether this processed matrix file contains data from a multiplexed experiment.",
            "type": "boolean",
            "submissionExample": {
                "appscript": "false"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/processed_matrix_file.md"
}
