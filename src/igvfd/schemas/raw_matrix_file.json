{
    "title": "Raw Matrix File",
    "$id": "/profiles/raw_matrix_file.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A file containing a raw matrix in H5 format.",
    "type": "object",
    "required": [
        "lab",
        "file_format"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/matrix_shared"
        },
        {
            "$ref": "file.json#/properties"
        }
    ],
    "allOf": [
        {
            "$merge": [
                "file.json#/allOf/0"
            ]
        }
    ],
    "properties": {
        "schema_version": {
            "default": "3"
        },
        "feature_keys": {
            "title": "Feature Keys",
            "description": "The category of identifiers used as keys for matrix features.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Feature Key",
                "type": "string",
                "enum": [
                    "antibody target",
                    "crispr guide ID",
                    "Ensembl gene ID",
                    "gene symbol",
                    "genomic coordinates",
                    "hash oligo",
                    "motif ID"
                ]
            }
        },
        "file_format": {
            "title": "File Format",
            "description": "The file format or extension of the file.",
            "type": "string",
            "enum": [
                "h5"
            ],
            "submissionExample": {
                "appscript": "h5"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/raw_matrix_file.md"
}
