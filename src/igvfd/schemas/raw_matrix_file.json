{
    "title": "Raw Matrix File",
    "$id": "/profiles/raw_matrix_file.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A file containing a raw matrix in H5 or H5AD format.",
    "type": "object",
    "required": [
        "lab",
        "file_format",
        "software",
        "genome_assembly",
        "is_multiplexed",
        "samples"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/matrix_shared"
        },
        {
            "$ref": "file.json#/properties"
        }
    ],
    "allOf": [
        {
            "$merge": [
                "file.json#/allOf/0"
            ]
        }
    ],
    "properties": {
        "schema_version": {
            "default": "5"
        },
        "feature_keys": {
            "title": "Feature Keys",
            "description": "The category of identifiers used as keys for matrix features.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Feature Key",
                "type": "string",
                "enum": [
                    "antibody target",
                    "crispr guide ID",
                    "Ensembl gene ID",
                    "gene symbol",
                    "genomic coordinates",
                    "hash oligo",
                    "motif ID"
                ]
            }
        },
        "file_format": {
            "title": "File Format",
            "description": "The file format or extension of the file.",
            "type": "string",
            "enum": [
                "h5",
                "h5ad"
            ],
            "submissionExample": {
                "appscript": "h5"
            }
        },
        "software": {
            "title": "Software",
            "description": "Software used to generate the matrix file.",
            "type": "string",
            "submissionExample": {
                "appscript": "Cell Ranger"
            }
        },
        "software_version": {
            "title": "Software Version",
            "description": "Version of the software used.",
            "type": "string",
            "submissionExample": {
                "appscript": "7.1.0"
            }
        },
        "genome_assembly": {
            "title": "Genome Assembly",
            "description": "Genome assembly used for alignment.",
            "type": "string",
            "enum": [
                "GRCh38",
                "GRCm39"
            ],
            "submissionExample": {
                "appscript": "GRCh38"
            }
        },
        "is_multiplexed": {
            "title": "Is Multiplexed",
            "description": "Whether this raw matrix file contains data from a multiplexed experiment.",
            "type": "boolean",
            "submissionExample": {
                "appscript": "false"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description",
        "software",
        "genome_assembly"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/raw_matrix_file.md"
}
