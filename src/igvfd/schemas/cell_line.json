{
    "title": "Cell Line",
    "$id": "/profiles/cell_line.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A concrete cell line schema inheriting from abstract Biosample class.",
    "type": "object",
    "required": [
        "lab",
        "donors",
        "sample_terms"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/author_metadata"
        },
        {
            "$ref": "biosample.json#/properties"
        },
        {
            "$ref": "mixins.json#/intended_cell_types"
        }
    ],
    "properties": {
        "schema_version": {
            "default": "2"
        },
        "host": {
            "title": "Host",
            "description": "The host organism for cell line transplantation scenarios.",
            "comment": "See donor.json for available identifiers.",
            "type": "string",
            "linkTo": "Donor"
        },
        "host_tissue": {
            "title": "Host Tissue",
            "description": "The host tissue used for xenotransplantation.",
            "comment": "See controlled_term.json for available identifiers.",
            "type": "string",
            "linkTo": "ControlledTerm",
            "submissionExample": {
                "appscript": "lattice:term-brain"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description",
        "sample_terms.term_name"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/cell_line.md"
}
