{
    "title": "Controlled Term",
    "$id": "/profiles/controlled_term.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A controlled vocabulary term from biological ontologies for sample classification and metadata annotation.",
    "type": "object",
    "required": [
        "term_id",
        "ontology_source"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases",
        "term_id"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/shared_status"
        }
    ],
    "properties": {
        "schema_version": {
            "default": "2"
        },
        "term_id": {
            "title": "Term ID",
            "description": "An ontology identifier from the specified ontology source.",
            "type": "string",
            "uniqueKey": "controlled_term:term_id",
            "pattern": "^(CL|EFO|MONDO|UBERON|HANCESTRO|HsapDv|MmusDv|PATO|NCBITaxon|FBbt|FBdv|ZFA|WBbt|WBls|CVCL|CHEBI|uniprot|anti-uniprot)[:_][A-Za-z0-9_]+$"
        },
        "ontology_source": {
            "title": "Ontology Source",
            "description": "The source ontology this term comes from.",
            "type": "string",
            "enum": [
                "CL",
                "EFO",
                "MONDO",
                "UBERON",
                "HANCESTRO",
                "HsapDv",
                "MmusDv",
                "PATO",
                "NCBITaxon",
                "FBbt",
                "FBdv",
                "ZFA",
                "WBbt",
                "WBls",
                "CVCL",
                "CHEBI",
                "UniProt"
            ]
        },
        "dbxrefs": {
            "title": "External References",
            "description": "External identifiers for this ontology term.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "External Identifier",
                "description": "An identifier from external resource.",
                "type": "string",
                "pattern": "^(PMID:[0-9]+|DOI:10\\.[0-9]+/.+)$"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description",
        "term_name",
        "definition",
        "synonyms"
    ],
    "exact_searchable_fields": [
        "@type",
        "term_id",
        "ontology_source"
    ],
    "changelog": "/profiles/changelogs/controlled_term.md"
}
