{
    "title": "Organoid",
    "$id": "/profiles/organoid.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A concrete organoid schema inheriting from abstract Biosample class.",
    "type": "object",
    "required": [
        "lab",
        "donors",
        "sample_terms"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "mixins.json#/author_metadata"
        },
        {
            "$ref": "biosample.json#/properties"
        },
        {
            "$ref": "mixins.json#/intended_cell_types"
        }
    ],
    "properties": {
        "schema_version": {
            "default": "3"
        },
        "origin_cell_types": {
            "title": "Origin Cell Types",
            "description": "Cell types from which this organoid was derived or that describe its cellular origin.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Origin Cell Type",
                "description": "An origin cell type.",
                "comment": "See controlled_term.json for available identifiers.",
                "type": "string",
                "linkTo": "ControlledTerm"
            },
            "submissionExample": {
                "appscript": "[\"lattice:term-t-cell\"]"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description",
        "multiplexing_barcodes",
        "RT_indexes",
        "sample_terms.term_name",
        "developmental_stages.term_name",
        "origin_cell_types.term_name"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/organoid.md"
}
