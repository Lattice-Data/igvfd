{
    "title": "Tabular File",
    "$id": "/profiles/tabular_file.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "A file containing tabular data in CSV or TSV format.",
    "type": "object",
    "required": [
        "lab",
        "file_format",
        "content_type"
    ],
    "identifyingProperties": [
        "uuid",
        "aliases"
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/basic_item"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/shared_status"
        },
        {
            "$ref": "file.json#/properties"
        }
    ],
    "allOf": [
        {
            "$merge": [
                "file.json#/allOf/0"
            ]
        }
    ],
    "properties": {
        "schema_version": {
            "default": "4"
        },
        "file_format": {
            "title": "File Format",
            "description": "The file format or extension of the file.",
            "type": "string",
            "enum": [
                "csv",
                "tsv"
            ],
            "submissionExample": {
                "appscript": "csv"
            }
        },
        "content_type": {
            "title": "Content Type",
            "description": "Describes the content of the tabular file.",
            "comment": "Content Type describes the content of the file.",
            "type": "string",
            "enum": [
                "guide RNA sequences"
            ],
            "enum_descriptions": {
                "guide RNA sequences": "The sequences of guide RNAs designed for genome editing using CRISPR."
            },
            "submissionExample": {
                "appscript": "guide RNA sequences"
            }
        }
    },
    "fuzzy_searchable_fields": [
        "aliases",
        "description"
    ],
    "exact_searchable_fields": [
        "@type"
    ],
    "changelog": "/profiles/changelogs/tabular_file.md"
}
